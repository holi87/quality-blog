---
import { t, getLocalePath, type Locale } from '../i18n/translations';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath = '' } = Astro.props;
const strings = t(locale);
const otherLocale = locale === 'pl' ? 'en' : 'pl';

const isHome = currentPath === '/' || currentPath === '';
const isBlog = currentPath.startsWith('/blog');
const isAbout = currentPath.includes('o-projekcie') || currentPath.includes('about');
---

<nav class="site-nav" aria-label="Primary">
  <div class="nav-inner">
    <a href={getLocalePath(locale, '/')} class="logo" aria-label="quality blog — home">
      <svg class="logomark" width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
        <defs>
          <linearGradient id="qb-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="var(--accent)" />
            <stop offset="1" stop-color="var(--accent-2)" />
          </linearGradient>
        </defs>
        <rect x="2" y="2" width="28" height="28" rx="7" fill="none" stroke="url(#qb-grad)" stroke-width="2" />
        <circle cx="22" cy="22" r="3.5" fill="var(--accent)" />
        <path d="M10 10 L18 10 L18 18" fill="none" stroke="var(--fg)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="logotype">
        <span class="logo-main">quality</span><span class="logo-sub">blog</span>
      </span>
    </a>

    <div class="nav-links">
      <a href={getLocalePath(locale, '/')} class:list={[{ active: isHome }]}>
        <span>{strings.nav.home}</span>
      </a>
      <a href={getLocalePath(locale, '/blog/')} class:list={[{ active: isBlog }]}>
        <span>{strings.nav.blog}</span>
      </a>
      <a href={getLocalePath(locale, locale === 'pl' ? '/o-projekcie/' : '/about/')} class:list={[{ active: isAbout }]}>
        <span>{strings.nav.about}</span>
      </a>

      <div class="nav-divider" aria-hidden="true"></div>

      <button
        type="button"
        class="icon-btn"
        data-theme-toggle
        aria-label={locale === 'pl' ? 'Przełącz motyw' : 'Toggle theme'}
        title={locale === 'pl' ? 'Przełącz motyw' : 'Toggle theme'}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="icon-sun">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="icon-moon">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a href={getLocalePath(otherLocale, '/')} class="lang-switch">
        {locale === 'pl' ? 'EN' : 'PL'}
      </a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    background: color-mix(in oklab, var(--bg) 72%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px clamp(20px, 4vw, 40px);
    max-width: var(--max-width);
    margin-inline: auto;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .logomark {
    flex-shrink: 0;
  }
  .logotype {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--fg);
  }
  .logo-sub {
    font-style: italic;
    color: var(--accent);
    font-variation-settings: 'SOFT' 80;
  }
  .nav-links {
    display: flex;
    gap: 4px;
    align-items: center;
  }
  .nav-links a {
    position: relative;
    color: var(--fg-muted);
    padding: 8px 12px;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
    border-radius: 8px;
    transition: color 180ms ease, background 180ms ease;
  }
  .nav-links a:hover {
    color: var(--fg);
    background: var(--bg-elev);
  }
  .nav-links a.active {
    color: var(--fg);
  }
  .nav-links a.active::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 2px;
    height: 1.5px;
    background: linear-gradient(to right, var(--accent), var(--accent-2));
    border-radius: 2px;
  }
  .nav-divider {
    width: 1px;
    height: 18px;
    background: var(--border);
    margin: 0 6px;
  }
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--fg-muted);
    position: relative;
    transition: color 180ms ease, background 180ms ease;
  }
  .icon-btn:hover {
    color: var(--fg);
    background: var(--bg-elev);
  }
  .icon-btn .icon-sun,
  .icon-btn .icon-moon {
    position: absolute;
    transition: opacity 220ms ease, transform 220ms ease;
  }
  :global([data-theme='dark']) .icon-sun { opacity: 1; transform: scale(1) rotate(0); }
  :global([data-theme='dark']) .icon-moon { opacity: 0; transform: scale(0.6) rotate(-90deg); }
  :global([data-theme='light']) .icon-sun { opacity: 0; transform: scale(0.6) rotate(90deg); }
  :global([data-theme='light']) .icon-moon { opacity: 1; transform: scale(1) rotate(0); }

  .lang-switch {
    font-family: var(--font-mono) !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    letter-spacing: 0.05em;
    color: var(--fg-muted) !important;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    padding: 6px 10px !important;
    border-radius: 8px !important;
    text-transform: uppercase;
  }
  .lang-switch:hover {
    border-color: var(--accent);
    color: var(--fg) !important;
    background: var(--bg-elev) !important;
  }
  .lang-switch.active::after { display: none; }

  @media (max-width: 640px) {
    .nav-inner { padding: 12px 16px; }
    .nav-links { gap: 0; }
    .nav-links a { padding: 6px 8px; font-size: 13px; }
    .nav-divider { margin: 0 2px; }
    .logo-main { display: none; }
    .logo-sub { font-size: 22px; }
  }
</style>
