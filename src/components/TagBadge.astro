---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<span class="tag-badge">{tag}</span>

<style>
  .tag-badge {
    background: var(--border-card);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
    color: var(--text-primary);
    display: inline-block;
  }
</style>
