---
import { t, type Locale, getLocalePath } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const rssLabel = locale === 'pl' ? 'Kanał RSS' : 'RSS feed';
const blogLabel = locale === 'pl' ? 'Blog' : 'Blog';
const aboutLabel = locale === 'pl' ? 'O projekcie' : 'About';
const exploreLabel = locale === 'pl' ? 'Odkryj' : 'Explore';
const findUsLabel = locale === 'pl' ? 'Znajdź nas' : 'Find us';
---

<footer class="site-footer">
  <div class="footer-top container">
    <div class="brand">
      <div class="logo-row">
        <svg width="24" height="24" viewBox="0 0 32 32" aria-hidden="true">
          <defs>
            <linearGradient id="fb-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="var(--accent)" />
              <stop offset="1" stop-color="var(--accent-2)" />
            </linearGradient>
          </defs>
          <rect x="2" y="2" width="28" height="28" rx="7" fill="none" stroke="url(#fb-grad)" stroke-width="2" />
          <circle cx="22" cy="22" r="3.5" fill="var(--accent)" />
          <path d="M10 10 L18 10 L18 18" fill="none" stroke="var(--fg)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="brand-name">quality<em>blog</em></span>
      </div>
      <p class="tagline">
        {locale === 'pl'
          ? 'Praktyczna wiedza o smart home i AI — bez marketingowego szumu.'
          : 'Practical knowledge about smart home and AI — no marketing fluff.'}
      </p>
    </div>

    <div class="col">
      <p class="col-title eyebrow">{exploreLabel}</p>
      <ul>
        <li><a href={getLocalePath(locale, '/')}>{strings.nav.home}</a></li>
        <li><a href={getLocalePath(locale, '/blog/')}>{blogLabel}</a></li>
        <li><a href={getLocalePath(locale, locale === 'pl' ? '/o-projekcie/' : '/about/')}>{aboutLabel}</a></li>
      </ul>
    </div>

    <div class="col">
      <p class="col-title eyebrow">{findUsLabel}</p>
      <ul>
        <li><a href={getLocalePath(locale, '/rss.xml')}>{rssLabel}</a></li>
        <li><a href="https://qualitycat.pl" target="_blank" rel="noopener">qualitycat.pl ↗</a></li>
        <li><a href={locale === 'pl' ? '/en/' : '/pl/'}>{locale === 'pl' ? 'English version' : 'Wersja polska'}</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom container">
    <span class="made-by">
      {strings.footer.madeBy} <a href="https://qualitycat.pl" target="_blank" rel="noopener">Quality Cat</a>
    </span>
    <span class="copy">&copy; {new Date().getFullYear()} · <span class="mono">quality-blog.eu</span></span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    padding-block: 56px 28px;
    border-top: 1px solid var(--border-soft);
    background: linear-gradient(to bottom, transparent, color-mix(in oklab, var(--bg-elev) 50%, transparent));
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border-soft);
  }

  .brand .logo-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
  .brand-name em {
    font-style: italic;
    color: var(--accent);
    font-variation-settings: 'SOFT' 80;
  }
  .tagline {
    margin-top: 14px;
    color: var(--fg-muted);
    font-size: 14px;
    max-width: 42ch;
    line-height: 1.55;
  }

  .col-title {
    margin-bottom: 12px;
    color: var(--fg-subtle);
  }
  .col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .col a {
    color: var(--fg-muted);
    font-size: 14px;
    transition: color 180ms;
  }
  .col a:hover { color: var(--accent); }

  .footer-bottom {
    margin-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .footer-bottom a { color: var(--accent); }
  .footer-bottom a:hover { text-decoration: underline; }
  .mono { color: var(--fg-muted); text-transform: none; letter-spacing: 0; }

  @media (max-width: 720px) {
    .footer-top { grid-template-columns: 1fr; gap: 28px; }
    .footer-bottom { flex-direction: column; gap: 10px; align-items: flex-start; }
  }
</style>
