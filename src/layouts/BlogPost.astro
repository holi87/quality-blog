---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { t, type Locale } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  date: Date;
  readingTime: number;
  tags: string[];
  locale: Locale;
  slug?: string;
}

const { title, description, date, readingTime, tags, locale, slug = '' } = Astro.props;
const strings = t(locale);

const formattedDate = date.toLocaleDateString(locale === 'pl' ? 'pl-PL' : 'en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const iso = date.toISOString();
const primary = (tags[0] ?? 'default')
  .toLowerCase()
  .replace(/\//g, '-')
  .replace(/[^a-z0-9-]+/g, '-')
  .replace(/^-+|-+$/g, '');

const tocLabel = locale === 'pl' ? 'Spis treści' : 'On this page';
const copyLabel = locale === 'pl' ? 'Kopiuj' : 'Copy';
const copiedLabel = locale === 'pl' ? 'Skopiowano' : 'Copied';
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  currentPath="/blog"
  ogType="article"
  publishedTime={date}
  tags={tags}
>
  <article class="post" data-cat={primary}>
    <div class="post-accent" aria-hidden="true"></div>

    <header class="post-header container">
      <nav class="breadcrumbs eyebrow" aria-label="Breadcrumb">
        <a href={`/${locale}/`}>{locale === 'pl' ? 'Home' : 'Home'}</a>
        <span class="sep">/</span>
        <a href={`/${locale}/blog/`}>blog</a>
        <span class="sep">/</span>
        <span class="current">{tags[0]?.toLowerCase() ?? 'post'}</span>
      </nav>

      <h1 class="post-title display">{title}</h1>
      <p class="post-desc">{description}</p>

      <div class="post-meta">
        <time datetime={iso}>{formattedDate}</time>
        <span class="sep" aria-hidden="true">·</span>
        <span>{readingTime} {strings.posts.readingTime}</span>
        <span class="sep" aria-hidden="true">·</span>
        <div class="post-tags">
          {tags.map((tag) => <Tag label={tag} variant="ghost" />)}
        </div>
      </div>
    </header>

    <div class="post-body container">
      <aside class="toc" aria-label={tocLabel}>
        <div class="toc-inner">
          <p class="eyebrow">{tocLabel}</p>
          <ol id="toc-list"></ol>
        </div>
      </aside>

      <div class="post-content" id="post-content" data-copy-label={copyLabel} data-copied-label={copiedLabel}>
        <slot />
      </div>
    </div>

    <footer class="post-footer container">
      <a class="back-link" href={`/${locale}/blog/`}>← {strings.posts.allPosts}</a>
    </footer>

    <div class="container">
      <RelatedPosts currentSlug={slug} currentTags={tags} locale={locale} />
    </div>
  </article>

  <script>
    function buildTOC() {
      const content = document.getElementById('post-content');
      const list = document.getElementById('toc-list');
      if (!content || !list) return;

      const headings = content.querySelectorAll<HTMLHeadingElement>('h2, h3');
      if (headings.length < 2) {
        const aside = list.closest('.toc') as HTMLElement | null;
        if (aside) aside.style.display = 'none';
        return;
      }

      list.innerHTML = '';
      headings.forEach((h) => {
        if (!h.id) {
          h.id = h.textContent
            ?.toLowerCase()
            .normalize('NFKD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+|-+$/g, '') ?? '';
        }
        const li = document.createElement('li');
        li.className = 'toc-' + h.tagName.toLowerCase();
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        list.appendChild(li);
      });

      // Highlight active heading on scroll
      const links = list.querySelectorAll<HTMLAnchorElement>('a');
      const byId = new Map<string, HTMLAnchorElement>();
      links.forEach((a) => byId.set(a.getAttribute('href')!.slice(1), a));
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const id = (entry.target as HTMLElement).id;
            const link = byId.get(id);
            if (!link) return;
            if (entry.isIntersecting) {
              links.forEach((l) => l.classList.remove('is-active'));
              link.classList.add('is-active');
            }
          });
        },
        { rootMargin: '-20% 0px -60% 0px', threshold: 0 },
      );
      headings.forEach((h) => io.observe(h));
    }

    function addCopyButtons() {
      const content = document.getElementById('post-content');
      if (!content) return;
      const copyLabel = content.dataset.copyLabel ?? 'Copy';
      const copiedLabel = content.dataset.copiedLabel ?? 'Copied';

      const pres = content.querySelectorAll<HTMLPreElement>('pre');
      pres.forEach((pre) => {
        if (pre.querySelector('.copy-btn')) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.textContent = copyLabel;
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.innerText ?? pre.innerText;
          try {
            await navigator.clipboard.writeText(code);
            btn.textContent = copiedLabel;
            btn.classList.add('is-copied');
            setTimeout(() => {
              btn.textContent = copyLabel;
              btn.classList.remove('is-copied');
            }, 1600);
          } catch (_) { /* ignore */ }
        });
        pre.appendChild(btn);
      });
    }

    function init() {
      buildTOC();
      addCopyButtons();
    }
    init();
    document.addEventListener('astro:page-load', init);
  </script>
</BaseLayout>

<style>
  .post {
    --card-accent: var(--cat, var(--accent));
    position: relative;
    padding-block: clamp(32px, 5vw, 60px) clamp(48px, 6vw, 80px);
  }
  .post-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 380px;
    background:
      radial-gradient(ellipse 50% 60% at 30% 0%, color-mix(in oklab, var(--card-accent) 15%, transparent), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .post > * { position: relative; z-index: 1; }

  .post-header {
    max-width: 880px;
    margin-bottom: 48px;
  }
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    font-size: 11px;
  }
  .breadcrumbs a {
    color: var(--fg-muted);
    transition: color 180ms;
  }
  .breadcrumbs a:hover { color: var(--fg); }
  .breadcrumbs .sep { color: var(--border); }
  .breadcrumbs .current { color: var(--fg); }

  .post-title {
    font-size: var(--step-5);
    color: var(--fg);
    max-width: 20ch;
    line-height: 1.05;
  }
  .post-desc {
    margin-top: 20px;
    font-size: var(--step-1);
    color: var(--fg-muted);
    max-width: 60ch;
    line-height: 1.55;
  }
  .post-meta {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
  }
  .post-meta .sep { opacity: 0.5; }
  .post-tags {
    display: inline-flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .post-body {
    display: grid;
    grid-template-columns: 220px minmax(0, 720px);
    gap: clamp(32px, 5vw, 72px);
    align-items: start;
    max-width: 1040px;
  }

  .toc {
    position: sticky;
    top: 88px;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .toc .eyebrow { margin-bottom: 12px; }
  .toc ol {
    list-style: none;
    padding: 0;
    border-left: 1px solid var(--border-soft);
  }
  .toc li { margin: 0; }
  .toc li a {
    display: block;
    padding: 5px 14px;
    color: var(--fg-muted);
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 160ms, border-color 160ms;
    line-height: 1.4;
    font-size: 12px;
  }
  .toc li a:hover { color: var(--fg); }
  .toc li.toc-h3 a { padding-left: 26px; color: var(--fg-subtle); }
  .toc li a.is-active {
    color: var(--fg);
    border-left-color: var(--card-accent);
  }

  .post-footer {
    max-width: 880px;
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--border-soft);
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--card-accent);
    transition: opacity 180ms;
  }
  .back-link:hover { opacity: 0.7; }

  @media (max-width: 900px) {
    .post-body { grid-template-columns: 1fr; }
    .toc { position: static; order: 2; margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border-soft); }
  }
</style>

<style is:global>
  /* ─── Long-form post content ─────────────────────────────────────── */
  .post-content {
    font-size: var(--step-0);
    color: var(--fg);
    line-height: 1.8;
  }
  .post-content > * + * { margin-top: 1.4em; }

  .post-content p {
    color: var(--fg);
    font-size: 17px;
    line-height: 1.8;
  }
  .post-content p + p { margin-top: 1em; }

  .post-content h2,
  .post-content h3,
  .post-content h4 {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--fg);
    line-height: 1.2;
    font-variation-settings: 'SOFT' 30, 'opsz' 144;
    scroll-margin-top: 100px;
  }
  .post-content h2 {
    font-size: clamp(24px, 2vw + 12px, 32px);
    margin-top: 2.2em;
    margin-bottom: 0.6em;
    padding-top: 0.6em;
    border-top: 1px solid var(--border-soft);
  }
  .post-content h3 {
    font-size: clamp(20px, 1.5vw + 10px, 24px);
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  .post-content h4 {
    font-size: 18px;
    margin-top: 1.8em;
    margin-bottom: 0.4em;
  }

  .post-content a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 35%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 180ms;
  }
  .post-content a:hover {
    text-decoration-color: var(--accent);
  }

  .post-content ul,
  .post-content ol {
    padding-left: 1.4em;
    color: var(--fg);
  }
  .post-content li { margin-bottom: 0.4em; }
  .post-content li::marker { color: var(--fg-subtle); }

  .post-content strong {
    color: var(--fg);
    font-weight: 600;
  }
  .post-content em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: 'SOFT' 70;
  }

  .post-content blockquote {
    margin: 2em 0;
    padding: 16px 22px;
    border-left: 3px solid var(--accent);
    background: color-mix(in oklab, var(--accent) 6%, var(--bg-elev));
    border-radius: 0 8px 8px 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    color: var(--fg);
  }
  .post-content blockquote p { font-size: inherit; line-height: 1.55; }

  .post-content hr {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border), transparent);
    margin: 3em 0;
  }

  /* Inline code */
  .post-content :not(pre) > code {
    background: var(--bg-code);
    border: 1px solid var(--border-soft);
    border-radius: 5px;
    padding: 1px 6px;
    font-size: 0.88em;
    color: var(--accent);
  }

  /* Code blocks (Shiki renders .astro-code) */
  .post-content pre,
  .post-content .astro-code {
    position: relative;
    background: var(--bg-code) !important;
    border: 1px solid var(--border-soft);
    border-radius: 10px;
    padding: 20px 22px;
    overflow-x: auto;
    font-size: 13.5px;
    line-height: 1.6;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--fg) 3%, transparent);
  }
  .post-content pre code,
  .post-content .astro-code code {
    font-family: var(--font-mono) !important;
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  /* Copy button */
  .post-content pre .copy-btn,
  .post-content .astro-code .copy-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 5px 9px;
    border-radius: 6px;
    color: var(--fg-muted);
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    border: 1px solid var(--border);
    cursor: pointer;
    opacity: 0;
    transition: opacity 180ms, color 180ms, border-color 180ms;
  }
  .post-content pre:hover .copy-btn,
  .post-content .astro-code:hover .copy-btn,
  .post-content .copy-btn:focus-visible {
    opacity: 1;
  }
  .post-content .copy-btn:hover {
    color: var(--fg);
    border-color: var(--accent);
  }
  .post-content .copy-btn.is-copied {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Light mode override for Shiki — use CSS vars --shiki-light swapping */
  :root[data-theme='light'] .astro-code,
  :root[data-theme='light'] .astro-code span {
    color: var(--shiki-light) !important;
    background-color: var(--shiki-light-bg) !important;
    font-style: var(--shiki-light-font-style) !important;
    font-weight: var(--shiki-light-font-weight) !important;
    text-decoration: var(--shiki-light-text-decoration) !important;
  }

  .post-content img {
    border-radius: 10px;
    border: 1px solid var(--border-soft);
  }
</style>
